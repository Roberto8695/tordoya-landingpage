                </div>
                <div className="space-y-1.5">
                  <label className="text-xs font-semibold text-foreground/70">Orden</label>
                  <input type="number" min={0} value={form.orden} onChange={(e) => handleChange("orden", parseInt(e.target.value) || 0)}
