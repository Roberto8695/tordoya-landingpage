// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Especialidad {
  id        String    @id @default(uuid())
  slug      String    @unique
  nombre    String
  icon      String    @default("HiOutlineViewList")
  color     String    @default("primary")
  imagen    String
  activo    Boolean   @default(true)
  orden     Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  servicios Servicio[]

  @@map("especialidades")
}

model Servicio {
  id              String       @id @default(uuid())
  slug            String       @unique
  nombre          String
  descripcion     String?
  precio         ault(true)
  orden           Int          @default(0)

  especialidadId  String
  especialidad    Especialidad @relation(fields: [especialidadId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("servicios")
}

model ConfigHeader {
  id        String   @id @default(uuid())
  logo      String   @default("/image/logo_h.webp")
  ctaText   String   @default("Agenda tu cita")
  ctaLink   String   @default("#contacto")
  navItems  Json     @default("[{\"label\":\"Inicio\",\"href\":\"#inicio\"},{\"label\":\"Nosotros\",\"href\":\"#nosotros\"},{\"label\":\"Servicios\",\"href\":\"#servicios\"},{\"label\":\"Contáctanos\",\"href\":\"#contacto\"}]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("config_header")
}

model ConfigFooter {
  id              String   @id @default(uuid())
  logo            String   @default("/image/logo-white.webp")
  description     String   @default("Servicios avanzados de imagenología médica y diagnóstico con tecnología de vanguardia")
  tags            Json     @default("[\"Calidad\",\"Precisión\",\"Confianza\"]")
  navItems        Json     @default("[{\"label\":\"Inicio\",\"href\":\"#inicio\"},{\"label\":\"Nosotros\",\"href\":\"#nosotros\"},{\"label\":\"Servicios\",\"href\":\"#servicios\"},{\"label\":\"Contáctanos\",\"href\":\"#contacto\"}]")
  contactAddress  String   @default("Av. Río Mixcoac 39, esq. Calle Ceres, CP 03940, Col. Crédito Constructor, Benito Juárez, CDMX.")
  contactPhone    String   @default("+52 1 55 4715 7971")
  contactEmail    String   @default("diagnosticoultrasonidotordoya@gmail.com")
  copyrightText   String   @default("© {year} Tordoya. Todos los derechos reservados.")
  copyrightSubtext String  @default("Soluciones integrales en diagnóstico por ultrasonido.")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("config_footer")
}

enum Role {
  ADMIN
  EDITOR
}